Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{
    RowBox[{"\[Alpha]", ">", "0"}], "&&", 
    RowBox[{"\[Beta]", ">", "0"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"f", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Beta]", "^", "\[Alpha]"}], "/", 
      RowBox[{"Gamma", "[", "\[Alpha]", "]"}]}], ")"}], " ", 
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{"\[Alpha]", "-", "1"}], ")"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Beta]"}], "*", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"bounds", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], ";"}], "\n", 
 RowBox[{"EV", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"x", " ", "f"}], ",", "bounds"}], "]"}]}], "\n", 
 RowBox[{"Var", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "-", "EV"}], ")"}], "^", "2"}], " ", "f"}], ",", 
    "bounds"}], "]"}]}], "\n", 
 RowBox[{"$Assumptions", "=", "Null"}]}], "Input",
 CellChangeTimes->{{3.983024517054014*^9, 3.983024517054014*^9}},
