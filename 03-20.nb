Cell[BoxData[{
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"x", "-", "1"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", "b"}], "}"}], "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"A", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{"g", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"k", "=", 
  RowBox[{"1", "/", "A"}]}], "\[IndentingNewLine]", 
 RowBox[{"f", "=", 
  RowBox[{
   RowBox[{"k", " ", "g"}], "//", "Expand"}]}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{"f", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}], "==", "1"}]}], "\[IndentingNewLine]", 
 RowBox[{"EV", " ", "=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"x", " ", "f"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Var", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "-", "EV"}], ")"}], "^", "2"}], "f"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"f", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "1.5", ",", "2.6"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"F", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{"f", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "x"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
