Cell[CellGroupData[{

Cell["Method of Moments Introduction", "Section",
 CellChangeTimes->{{3.9830242492975197`*^9, 
  3.9830242554739*^9}},ExpressionUUID->"4b70a927-ee83-8045-9a5f-8bcc261a6526"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{"\[Sigma]", ">", "0"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"f", "=", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", "*", "\[Pi]", "*", 
       RowBox[{"\[Sigma]", "^", "2"}]}], "]"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "/", "2"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "\[Mu]"}], ")"}], "/", "\[Sigma]"}], ")"}], "^", 
       "2"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"bounds", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], ";"}], "\n", 
 RowBox[{"EV", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"x", " ", "f"}], ",", "bounds"}], "]"}]}], "\n", 
 RowBox[{"Var", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "-", "EV"}], ")"}], "^", "2"}], " ", "f"}], ",", 
    "bounds"}], "]"}]}], "\n", 
 RowBox[{"$Assumptions", "=", "Null"}]}], "Input",
 CellChangeTimes->{{3.983024256465927*^9, 3.983024256465927*^9}},
